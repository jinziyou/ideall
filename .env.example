# myos 环境变量
# 复制为 .env.local 后按需修改（Next.js 自动加载 .env.local）

# =============================================================================
# SERVER_ADDR — super/server (Rust Axum API) 基址
#
# myos 在服务端（Server Component / Server Action）通过此地址访问后端。
# home / tool 的本地能力不依赖后端；info / community 需要可用的 super/server。
# =============================================================================

# --- 模式 A：官方 Wonita 信息服务（推荐给普通用户）---
# 使用官方运营的采集、图谱与鉴权 API。上线前将 TODO 替换为正式 API 基址。
# SERVER_ADDR=https://api.wonita.example

# --- 模式 B：本地开发 / 自托管后端 ---
# 在本机或内网自行运行 super/server（及完整 super 栈）时使用。
# wonita monorepo 内默认联调地址：
SERVER_ADDR=http://127.0.0.1:3001

# --- 模式 C：Docker Compose（与 super 同网络）---
# 由 peer/docker-compose.yml 注入，一般无需写入 .env.local。
# 单独 docker compose up 时在 compose 环境段设置：
#   MYOS_SERVER_ADDR=http://server:3001
#
# 需先创建与 super 共用的外部网络：
#   docker network create wonita_net

# =============================================================================
# 以下变量主要用于 Docker Compose（见 docker-compose.yml）
# =============================================================================

# MYOS_PORT=3000
# MYOS_SERVER_ADDR=http://server:3001
# WONITA_NETWORK=wonita_net
