# ideall 环境变量
# 复制为 .env.local 后按需修改（Next.js 自动加载 .env.local）

# =============================================================================
# SERVER_ADDR — wonita 服务 (Rust Axum API) 基址
#
# Web 形态：ideall 在服务端（Server Component / Server Action）通过 SERVER_ADDR 访问后端。
# App 形态（Tauri 静态导出）：客户端直连后端，读 NEXT_PUBLIC_SERVER_ADDR（见文末 App 段）。
# home / tool 的本地能力不依赖后端；info / community 需要可用的 wonita 服务。
# =============================================================================

# --- 模式 A：官方 Wonita 信息服务（普通用户）---
# 官方运营的采集 / 图谱 / 鉴权 API（域名 wonita.link，上线生效前可能暂不可达）。
# SERVER_ADDR=https://api.wonita.link   # 官方信息服务 API

# --- 模式 B：本地开发 / 自托管后端 ---
# 在本机或内网自行运行 wonita 服务（及完整 wonita 后端栈）时使用。
# wonita monorepo 内默认联调地址：
SERVER_ADDR=http://127.0.0.1:5021

# --- 模式 C：Docker Compose ---
# docker compose up 默认自建桥接网络 ideall_net, 开箱即用; SERVER_ADDR 由 IDEALL_SERVER_ADDR 注入
# (默认 http://host.docker.internal:5021, 指向宿主机上的后端)。
# 与同机部署的后端共用一张已有外部网络时, 叠加 docker-compose.override.example.yml (见该文件注释)。

# =============================================================================
# 以下变量主要用于 Docker Compose（见 docker-compose.yml）
# =============================================================================

# IDEALL_PORT=5020                                     # 宿主机映射端口
# IDEALL_SERVER_ADDR=http://host.docker.internal:5021  # 后端 API 基址 (官方或自托管)
# IDEALL_NETWORK=ideall_net                            # compose 自建桥接网络名

# =============================================================================
# App 形态（Tauri 静态导出）—— 见 docs/app.md
# 客户端直连后端，地址在构建期内联进静态包，故用 NEXT_PUBLIC_ 前缀（会进客户端 bundle）。
# 仅 `pnpm app:export` / `pnpm app:build` 时生效；web 形态用上面的 SERVER_ADDR。
# =============================================================================

# NEXT_PUBLIC_SERVER_ADDR=https://api.wonita.link   # app 直连的官方后端 API 基址
