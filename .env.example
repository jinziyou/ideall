# ideall 环境变量
# 复制为 .env.local 后按需修改（Next.js 自动加载 .env.local）
#
# ideall 仅以 App 形态运行（Tauri 静态导出，无 Node 生产服务端）。
# 客户端直连后端数据服务；地址在构建期内联进静态包，故主用 NEXT_PUBLIC_ 前缀（会进客户端 bundle）。
# home / tool 的本地能力不依赖后端；info / community 需要可用的 wonita 服务（需后端放行 CORS）。
#
# 开箱默认指向官方 wonita（ideall 独立仓库，不内嵌本地联调地址）。
# 联调自建 / 本地后端：复制本文件为 .env.local，把下方 NEXT_PUBLIC_SERVER_ADDR /
# NEXT_PUBLIC_EMBED_BASE 改成你的后端地址即可（.env.local 已被 .gitignore 忽略，不入库）。

# =============================================================================
# NEXT_PUBLIC_SERVER_ADDR — wonita apiserver 基址（App 客户端直连）
# =============================================================================

NEXT_PUBLIC_SERVER_ADDR=https://api.wonita.link

# =============================================================================
# SERVER_ADDR — 仅 `pnpm dev` 的 SSR 渲染期在服务端读取；不设时回退到上一项
# =============================================================================

# SERVER_ADDR=https://api.wonita.link

# =============================================================================
# NEXT_PUBLIC_EMBED_BASE — 被嵌入页 (wonita/portal) 基址
# (discover) 的 info/community 经 iframe 内嵌此地址的 /info 与 /community。
# 须与 src-tauri/tauri.conf.json 的 CSP frame-src + portal 的 frame-ancestors 一致。
# =============================================================================

NEXT_PUBLIC_EMBED_BASE=https://www.wonita.link

# =============================================================================
# NEXT_PUBLIC_XSTATE_INSPECT — 开发态 XState Stately Inspector (auth/sync 状态机)
# 默认开启 (pnpm dev / app:dev); 设为 0 关闭自动打开 Inspector 窗口 (仍保留 Redux flowProgress)。
# 可视化: https://stately.ai/inspector
# =============================================================================

# NEXT_PUBLIC_XSTATE_INSPECT=0

# 正确接收页: https://stately.ai/inspect  (不是 https://stately.ai/registry/inspect)

# =============================================================================
# IDEALL_BROWSER_CDP — Linux/WSL 内嵌浏览器后端 (Tauri/Rust 进程读取, 非 NEXT_PUBLIC_)
# 默认 WebKit 内嵌 (页面在 ideall 窗口内); 设为 1 启用 CDP 模式 (另开 Chrome 窗口, AI 自动化更强)。
# =============================================================================

# IDEALL_BROWSER_CDP=1
