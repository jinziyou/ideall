{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ideall",
  "version": "0.1.0",
  "identifier": "org.wonita.ideall",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:5020",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm app:export"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ideall",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; script-src 'self' tauri: 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src * data: blob:; font-src 'self' data:; connect-src 'self' tauri:; frame-src 'self' https://www.wonita.link https://wonita.link; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "本地优先的个人信息终端",
    "longDescription": "ideall — 本地优先的个人信息终端，一切皆文件·一切皆标签页 (home「我的」+ info/community/tool)。",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/jinziyou/ideall/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBNkEyMzJCMkRGNjU0OQpSV1JKWmQreU1xS21DaStmNmJwenU1MzJjMjVSWEJwM05UOGpna1RRMlBXYlFZdmJ2MmRveUF2NQo="
    }
  }
}
