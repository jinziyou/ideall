{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "guarded-filesystem",
  "description": "Native-picked repository grants: pick, inspect, revoke, stat, list, read and text write from the main window.",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "allow-guarded-fs-pick-root",
    "allow-guarded-fs-grant-info",
    "allow-guarded-fs-revoke-grant",
    "allow-guarded-fs-stat",
    "allow-guarded-fs-list",
    "allow-guarded-fs-read",
    "allow-guarded-fs-write-text"
  ]
}
