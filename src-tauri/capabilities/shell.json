{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "shell",
  "description": "本地 Shell 终端: 执行用户输入的系统命令 (仅桌面)",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "comment": "仅允许执行常见系统 shell; 程序名白名单, 不开放任意路径。",
      "allow": [
        {
          "args": true,
          "cmd": "sh",
          "name": "exec-sh"
        },
        {
          "args": true,
          "cmd": "bash",
          "name": "exec-bash"
        },
        {
          "args": true,
          "cmd": "zsh",
          "name": "exec-zsh"
        },
        {
          "args": true,
          "cmd": "fish",
          "name": "exec-fish"
        },
        {
          "args": true,
          "cmd": "cmd",
          "name": "exec-cmd"
        },
        {
          "args": true,
          "cmd": "powershell",
          "name": "exec-powershell"
        },
        {
          "args": true,
          "cmd": "pwsh",
          "name": "exec-pwsh"
        }
      ]
    }
  ]
}
