{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "browser",
  "description": "内嵌浏览器: 主窗口 (main) 控制子 webview 的自定义命令授权 (仅桌面)。被嵌的外站子 webview 本身零授权, 不调任何命令。",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "allow-open-browser-view",
    "allow-browser-set-bounds",
    "allow-browser-navigate",
    "allow-browser-back",
    "allow-browser-forward",
    "allow-browser-reload",
    "allow-browser-hide",
    "allow-browser-show",
    "allow-browser-close",
    "allow-browser-get-content",
    "allow-browser-click",
    "allow-browser-fill",
    "allow-browser-press",
    "allow-browser-list-interactive",
    "allow-browser-wait",
    "allow-browser-wait-for-selector"
  ]
}
