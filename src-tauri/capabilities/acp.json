{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "acp",
  "description": "ACP 外部智能体传输: 主窗口 (main) 经子进程 stdin/stdout 哑管道驱动外部 ACP 智能体的自定义命令授权 (仅桌面; program/args 来自用户设置, 非模型可控)。",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "allow-acp-spawn",
    "allow-acp-send",
    "allow-acp-close",
    "allow-acp-listen-start",
    "allow-acp-listen-stop",
    "allow-acp-server-send",
    "allow-acp-server-close",
    "allow-acp-which",
    "allow-acp-script-path",
    "allow-acp-run-once"
  ]
}
