{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "runtime-extensions",
  "description": "签名运行时扩展：主窗口可管理 publisher 信任根与签名撤销清单，安装、更新、回滚或卸载固定 App 数据目录中的包，并按已签名参数启动隔离的 stdio connector。",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "allow-runtime-extension-discover",
    "allow-runtime-extension-verify",
    "allow-runtime-extension-spawn",
    "allow-runtime-extension-publisher-list",
    "allow-runtime-extension-publisher-inspect",
    "allow-runtime-extension-publisher-trust",
    "allow-runtime-extension-publisher-rotation-inspect",
    "allow-runtime-extension-publisher-rotation-apply",
    "allow-runtime-extension-publisher-revoke",
    "allow-runtime-extension-revocation-import",
    "allow-runtime-extension-install",
    "allow-runtime-extension-rollback",
    "allow-runtime-extension-uninstall",
    "allow-runtime-extension-registry-snapshot",
    "allow-runtime-extension-registry-refresh",
    "allow-runtime-extension-update-prepare",
    "allow-runtime-extension-update-apply",
    "allow-runtime-extension-update-discard"
  ]
}
