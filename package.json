{
  "name": "ideall",
  "version": "0.1.0",
  "description": "开源、本地优先的个人信息终端 (home「我的」+ apps/info/community/tool)",
  "license": "Apache-2.0",
  "private": false,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "@babel/core@<=7.29.0": ">=7.29.6",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.7",
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "js-yaml@>=4.0.0 <=4.1.1": "4.3.0"
    }
  },
  "scripts": {
    "dev": "next dev -p 5020",
    "build": "next build",
    "tauri": "tauri",
    "app:dev": "node scripts/app-dev.mjs",
    "git:pull": "node scripts/git-pull.mjs",
    "git:setup": "node scripts/git-setup.mjs",
    "app:export": "next build",
    "app:build": "tauri build",
    "clean:next": "node scripts/clean-next.mjs",
    "lint": "eslint",
    "lint:actions": "node scripts/lint-actions.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm verify:base",
    "verify:base": "pnpm format:check && pnpm lint && pnpm lint:actions && pnpm clean:next && pnpm typecheck && pnpm test && pnpm gen:api:check && pnpm build",
    "verify:smoke": "node scripts/verify-full.mjs --smoke-only",
    "verify:smoke:static": "node scripts/verify-static-smoke.mjs",
    "verify:static-export": "node scripts/check-static-export.mjs",
    "verify:full": "node scripts/verify-full.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync:api": "node scripts/sync-server-openapi.mjs",
    "gen:api": "openapi-typescript openapi/server.json -o src/lib/api/server.d.ts",
    "gen:api:check": "openapi-typescript openapi/server.json -o node_modules/.cache/ideall/server.gen.d.ts && node scripts/gen-api-check.mjs",
    "test": "node --import tsx scripts/run-tests.mjs",
    "smoke:notes": "node scripts/smoke/notes.mjs",
    "smoke:files": "node scripts/smoke/files.mjs",
    "smoke:files:preview": "node scripts/smoke/files-preview.mjs",
    "smoke:plugins": "node scripts/smoke/plugins.mjs",
    "smoke:trash": "node scripts/smoke/trash.mjs",
    "serve:out": "node scripts/serve-out.mjs",
    "bump": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.0.0",
    "@ariakit/react": "^0.4.29",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@platejs/basic-nodes": "^53.0.0",
    "@platejs/code-block": "^53.0.0",
    "@platejs/combobox": "^53.0.0",
    "@platejs/indent": "^53.0.0",
    "@platejs/list": "^53.1.3",
    "@platejs/slash-command": "^53.0.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toolbar": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@reduxjs/toolkit": "^2.12.0",
    "@statelyai/inspect": "^0.7.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-http": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.6",
    "platejs": "^53",
    "react": "^19.2.5",
    "react-day-picker": "9.14.0",
    "react-dom": "^19.2.5",
    "react-redux": "^9.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "xstate": "^5.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "actionlint": "2.0.6",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.16",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
