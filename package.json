{
  "name": "ideall",
  "version": "0.1.0",
  "description": "开源、本地优先的个人信息终端 (home「我的」+ apps/info/community/tool)",
  "license": "Apache-2.0",
  "private": false,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "@babel/core@<=7.29.0": ">=7.29.6"
    }
  },
  "scripts": {
    "dev": "next dev -p 5020",
    "build": "next build",
    "tauri": "tauri",
    "app:dev": "node scripts/app-dev.mjs",
    "wsl:hosts": "node scripts/wsl-wonita-hosts.mjs",
    "wsl:hosts:apply": "bash scripts/wsl-hosts-apply.sh",
    "app:export": "next build",
    "app:build": "tauri build",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync:api": "node scripts/sync-server-openapi.mjs",
    "gen:api": "openapi-typescript openapi/server.json -o src/lib/api/server.d.ts",
    "gen:api:check": "openapi-typescript openapi/server.json -o node_modules/.cache/ideall/server.gen.d.ts && node scripts/gen-api-check.mjs",
    "test": "node --import tsx scripts/run-tests.mjs",
    "smoke:notes": "node scripts/smoke-notes.mjs",
    "serve:out": "node scripts/serve-out.mjs",
    "bump": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.0.0",
    "@ariakit/react": "^0.4.29",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@platejs/basic-nodes": "^53.0.0",
    "@platejs/code-block": "^53.0.0",
    "@platejs/combobox": "^53.0.0",
    "@platejs/indent": "^53.0.0",
    "@platejs/list": "^53.1.3",
    "@platejs/slash-command": "^53.0.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toolbar": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-http": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.6",
    "platejs": "^53",
    "react": "^19.2.5",
    "react-day-picker": "9.14.0",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.16",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
