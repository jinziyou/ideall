{
  "name": "myos",
  "version": "0.1.0",
  "description": "Wonita 用户界面 / 个人信息总控终端，home 信息中枢 + info/community/tool",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync:api": "node scripts/sync-server-openapi.mjs",
    "gen:api": "openapi-typescript openapi/server.json -o src/lib/api/server.d.ts",
    "gen:api:check": "openapi-typescript openapi/server.json -o /tmp/server.gen.d.ts && diff -q src/lib/api/server.d.ts /tmp/server.gen.d.ts",
    "test": "node --import ./node_modules/tsx/dist/loader.mjs --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@antv/g6": "^5.1.1",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "^19.2.5",
    "react-day-picker": "9.14.0",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
