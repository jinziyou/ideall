{
  "name": "ideall",
  "version": "0.2.0",
  "description": "开源、本地优先的个人信息终端 (home「我的」+ apps/info/community/tool)",
  "license": "Apache-2.0",
  "private": false,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "adm-zip": "0.6.0",
      "postcss@<8.5.10": ">=8.5.10",
      "@babel/core@<=7.29.0": ">=7.29.6",
      "brace-expansion@<2.0.0": "1.1.16",
      "brace-expansion@>=2.0.0 <3.0.0": "2.1.2",
      "brace-expansion@>=5.0.0 <5.0.7": "5.0.7",
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "js-yaml": "4.3.0"
    }
  },
  "scripts": {
    "dev": "pnpm semantic:bundle && next dev -p 5020",
    "build": "pnpm semantic:bundle && next build",
    "tauri": "tauri",
    "app:dev": "node scripts/app-dev.mjs",
    "git:pull": "node scripts/git-pull.mjs",
    "git:setup": "node scripts/git-setup.mjs",
    "app:export": "pnpm build && pnpm verify:static-export && pnpm verify:bundle && pnpm verify:semantic-runtime",
    "app:build": "tauri build",
    "clean:next": "node scripts/clean-next.mjs",
    "lint": "eslint",
    "lint:actions": "node scripts/lint-actions.mjs",
    "lint:storage": "node scripts/lint-storage-access.mjs",
    "lint:deps": "knip --include dependencies,devDependencies,unlisted --no-progress",
    "lint:dead-code": "knip --include files --no-progress",
    "lint:docs": "node scripts/check-docs.mjs",
    "typecheck": "tsc --noEmit",
    "native:check": "cd native && cargo check --locked --workspace --all-targets && cargo check --locked -p ideall-mobile --features mobile-ui-host-check",
    "native:test": "cd native && cargo test --locked --workspace",
    "native:lint": "cd native && cargo fmt --all -- --check && cargo clippy --locked -p ideall-protocol -p ideall-domain -p ideall-storage -p ideall-application -p ideall-sync -p ideall-sync-http -p ideall-agent -p ideall-acp -p ideall-secrets -p ideall-updater -p ideall-cli -p ideall-desktop --all-targets -- -D warnings && cargo clippy --locked -p ideall-mobile --features mobile-ui-host-check -- -D warnings",
    "native:dev": "cd native && cargo run --locked -p ideall-desktop",
    "native:build:desktop": "cd native && cargo build --locked --release -p ideall-desktop && bash scripts/package-desktop.sh",
    "native:android": "bash native/apps/ideall-mobile/build-mobile.sh android release",
    "native:android:bundle": "bash native/apps/ideall-mobile/build-mobile.sh android-bundle release",
    "native:ios:simulator": "bash native/apps/ideall-mobile/build-mobile.sh ios-simulator release",
    "native:ios:device": "bash native/apps/ideall-mobile/build-mobile.sh ios-device release",
    "native:ios:archive": "bash native/apps/ideall-mobile/build-mobile.sh ios-archive release",
    "native:ios:ipa": "bash native/apps/ideall-mobile/build-mobile.sh ios-ipa release",
    "verify": "pnpm verify:base",
    "verify:checks": "pnpm format:check && pnpm lint && pnpm lint:actions && pnpm lint:storage && pnpm lint:deps && pnpm lint:dead-code && pnpm lint:docs && pnpm version:check && pnpm clean:next && pnpm typecheck && pnpm test:coverage && pnpm test:scripts && pnpm gen:api:check",
    "verify:base": "pnpm verify:checks && pnpm app:export",
    "verify:bundle": "node scripts/check-bundle-budget.mjs",
    "verify:semantic-runtime": "node scripts/check-semantic-runtime-budget.mjs",
    "verify:smoke": "node scripts/verify-full.mjs --smoke-only",
    "verify:smoke:static": "node scripts/verify-static-smoke.mjs",
    "verify:static-export": "node scripts/check-static-export.mjs",
    "verify:full": "node scripts/verify-full.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "semantic:bundle": "node scripts/build-semantic-worker.mjs",
    "registry:prepare": "node scripts/extension-registry-artifacts.mjs prepare",
    "registry:verify": "node scripts/extension-registry-artifacts.mjs verify",
    "sync:api": "node scripts/sync-server-openapi.mjs",
    "gen:api": "openapi-typescript openapi/server.json -o src/lib/api/server.d.ts",
    "gen:api:provenance:check": "node scripts/check-server-openapi-provenance.mjs",
    "gen:api:check": "pnpm gen:api:provenance:check && openapi-typescript openapi/server.json -o node_modules/.cache/ideall/server.gen.d.ts && node scripts/gen-api-check.mjs",
    "test": "node --import tsx scripts/run-tests.mjs",
    "test:coverage": "c8 node --import tsx scripts/run-tests.mjs",
    "test:scripts": "node scripts/run-script-tests.mjs",
    "smoke:notes": "node scripts/smoke/notes.mjs",
    "smoke:files": "node scripts/smoke/files.mjs",
    "smoke:files:preview": "node scripts/smoke/files-preview.mjs",
    "smoke:plugins": "node scripts/smoke/plugins.mjs",
    "smoke:trash": "node scripts/smoke/trash.mjs",
    "serve:out": "node scripts/serve-out.mjs",
    "bump": "node scripts/bump-version.mjs",
    "version:check": "node scripts/check-version.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@ariakit/react": "^0.4.34",
    "@huggingface/transformers": "4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@platejs/basic-nodes": "^53.0.0",
    "@platejs/code-block": "^53.0.0",
    "@platejs/combobox": "^53.0.0",
    "@platejs/indent": "^53.0.0",
    "@platejs/list": "^53.1.3",
    "@platejs/slash-command": "^53.0.0",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@statelyai/inspect": "^0.7.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-http": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "highlight.js": "11.11.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "platejs": "^53",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xstate": "^5.32.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "actionlint": "2.0.6",
    "c8": "11.0.0",
    "esbuild": "0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "knip": "6.27.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
