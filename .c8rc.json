{
  "all": true,
  "include": [
    "src/protocol/**/*.ts",
    "src/filesystem/**/*.ts",
    "src/engines/**/*.ts",
    "src/shell/boot*.ts",
    "src/shell/runtime-extensions.ts",
    "src/shell/runtime-extensions/**/*.ts",
    "src/workspace/store.ts",
    "src/workspace/store/**/*.ts",
    "src/plugins/shared/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"],
  "check-coverage": true,
  "statements": 80,
  "branches": 75,
  "functions": 78,
  "lines": 80,
  "reporter": ["text", "lcov"],
  "reports-dir": "node_modules/.cache/ideall/coverage"
}
