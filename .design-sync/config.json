{
  "pkg": "ideall",
  "globalName": "IdeallUI",
  "projectId": "ea09cff9-31c7-4bd2-a7c5-9198336cabca",
  "shape": "package",
  "buildCmd": "node .design-sync/compile-css.mjs",
  "srcDir": "src/ui",
  "tsconfig": "tsconfig.json",
  "cssEntry": ".design-sync/.cache/tailwind.css",
  "guidelinesGlob": [],
  "readmeHeader": ".design-sync/conventions.md",
  "componentSrcMap": {
    "Badge": "src/ui/badge.tsx",
    "Button": "src/ui/button.tsx",
    "Calendar": "src/ui/calendar.tsx",
    "Card": "src/ui/card.tsx",
    "Checkbox": "src/ui/checkbox.tsx",
    "Command": "src/ui/command.tsx",
    "Dialog": "src/ui/dialog.tsx",
    "DropdownMenu": "src/ui/dropdown-menu.tsx",
    "EmptyState": "src/ui/empty-state.tsx",
    "HoverCard": "src/ui/hover-card.tsx",
    "Input": "src/ui/input.tsx",
    "Label": "src/ui/label.tsx",
    "Popover": "src/ui/popover.tsx",
    "Select": "src/ui/select.tsx",
    "Separator": "src/ui/separator.tsx",
    "Sheet": "src/ui/sheet.tsx",
    "Toaster": "src/ui/sonner.tsx",
    "Table": "src/ui/table.tsx",
    "Tabs": "src/ui/tabs.tsx",
    "Textarea": "src/ui/textarea.tsx",
    "Tooltip": "src/ui/tooltip.tsx"
  },
  "overrides": {
    "Select": { "cardMode": "single", "primaryStory": "Open", "viewport": "360x340" },
    "Table": { "cardMode": "column" },
    "Dialog": { "cardMode": "single", "primaryStory": "Confirm", "viewport": "680x440" },
    "Sheet": { "cardMode": "single", "primaryStory": "RightPanel", "viewport": "600x440" },
    "Popover": { "cardMode": "single", "primaryStory": "Open", "viewport": "380x380" },
    "DropdownMenu": { "cardMode": "single", "primaryStory": "Open", "viewport": "340x360" },
    "HoverCard": { "cardMode": "single", "primaryStory": "Open", "viewport": "360x320" },
    "Tooltip": { "cardMode": "single", "primaryStory": "Open", "viewport": "340x220" },
    "Command": { "cardMode": "single", "primaryStory": "Palette", "viewport": "520x460" }
  }
}
