# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
# pnpm 本地内容寻址 store (不入库; 误提交可 git rm -r --cached .pnpm-store)
/.pnpm-store/

# testing
/coverage

# next.js
/.next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files（保留 .env.example 受 Git 管理）
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# app: Next 静态导出产物 (output: export)。Tauri 工程的 target/gen 见 src-tauri/.gitignore
/out/
/public/generated/
/registry-ready/
/native/target/
/native/apps/ideall-mobile/platforms/android/.gradle/
/native/apps/ideall-mobile/platforms/android/app/build/
/native/apps/ideall-mobile/platforms/android/app/src/main/jniLibs/
/native/apps/ideall-mobile/platforms/ios/Ideall.xcodeproj/
/native/apps/ideall-mobile/platforms/ios/build/

# redesign 设计探索 / 截图 scratch (本地参考, 不入库)
/redesign-mockups/

# 内部战略文档 (含竞品/变现坦白分析, 勿入公开仓库)
/docs/strategy-internal.md

# 根目录临时验证脚本 (应放在 scripts/)
/.verify-*.mjs

# local agent/harness state
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# 设计系统同步缓存与打包产物（由外部同步工具重建，不进入应用源码）
/.design-sync/
/.ds-sync/
/ds-bundle/
